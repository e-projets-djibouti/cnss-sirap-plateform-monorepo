{
  "name": "cnss-sirap-monorepo",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter frontend dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build:shared": "pnpm --filter @sirap/shared build",
    "db:migrate": "pnpm --filter backend prisma migrate dev",
    "db:generate": "pnpm --filter backend prisma generate",
    "db:seed": "pnpm --filter backend prisma db seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
